---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>California DUI Help</h1>
			<p>Clear, plain-English information about what happens after a DUI arrest in California.</p>
			<ul>
				<li><a href="/blog/california-dui-what-happens">What Happens After a California DUI Arrest</a></li>
			</ul>
		</main>
		<Footer />
	</body>
</html>
