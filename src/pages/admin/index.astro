---
export const prerender = false;
import { getSQL, initDB } from '../../lib/db';

const adminPassword = process.env.ADMIN_PASSWORD;
const authCookie = Astro.cookies.get('admin_auth');
const isAuthed = authCookie?.value === adminPassword;

let leads: any[] = [];
if (isAuthed) {
	await initDB();
	const sql = getSQL();
	leads = await sql`SELECT * FROM leads ORDER BY created_at DESC`;
}
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Admin — CaliDUIHelp Leads</title>
		<style>
			* { box-sizing: border-box; }
			body { font-family: sans-serif; margin: 0; background: #f4f6f9; color: #1a1a1a; }
			.login-wrap { max-width: 360px; margin: 8em auto; background: white; padding: 2em; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.1); }
			.login-wrap h1 { font-size: 1.3em; margin-bottom: 1em; }
			.login-wrap input { width: 100%; padding: 0.6em 0.8em; margin-bottom: 1em; border: 1px solid #ddd; border-radius: 5px; font-size: 1em; }
			.login-wrap button { width: 100%; background: #cc0000; color: white; border: none; padding: 0.7em; font-size: 1em; font-weight: 700; border-radius: 5px; cursor: pointer; }
			.login-wrap button:hover { background: #a30000; }
			#login-error { color: #cc0000; font-size: 0.9em; margin-top: 0.5em; display: none; }
			header { background: #cc0000; color: white; padding: 1em 2em; display: flex; justify-content: space-between; align-items: center; }
			header h1 { margin: 0; font-size: 1.2em; }
			header span { font-size: 0.85em; opacity: 0.85; }
			.container { max-width: 1100px; margin: 2em auto; padding: 0 1.5em; }
			.stats { display: flex; gap: 1em; margin-bottom: 2em; flex-wrap: wrap; }
			.stat-card { background: white; border-radius: 8px; padding: 1em 1.5em; flex: 1; min-width: 140px; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
			.stat-card .num { font-size: 2em; font-weight: 700; color: #cc0000; }
			.stat-card .label { font-size: 0.85em; color: #666; }
			table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.08); }
			th { background: #1a1a1a; color: white; padding: 0.75em 1em; text-align: left; font-size: 0.85em; }
			td { padding: 0.75em 1em; border-bottom: 1px solid #eee; font-size: 0.9em; vertical-align: top; }
			tr:last-child td { border-bottom: none; }
			tr:hover td { background: #fafafa; }
			.badge { display: inline-block; padding: 0.2em 0.6em; border-radius: 20px; font-size: 0.78em; font-weight: 700; }
			.badge-new { background: #fef3c7; color: #92400e; }
			.badge-sent { background: #d1fae5; color: #065f46; }
			.send-form input { padding: 0.35em 0.5em; border: 1px solid #ddd; border-radius: 4px; font-size: 0.85em; width: 180px; }
			.send-form button { background: #2337ff; color: white; border: none; padding: 0.35em 0.8em; border-radius: 4px; font-size: 0.85em; cursor: pointer; margin-left: 0.3em; }
			.send-form button:hover { background: #000d8a; }
			.sent-label { color: #065f46; font-size: 0.85em; font-weight: 600; }
		</style>
	</head>
	<body>
		{!isAuthed ? (
			<div class="login-wrap">
				<h1>Admin Login</h1>
				<input type="password" id="pw-input" placeholder="Enter admin password" />
				<button id="login-btn">Log In</button>
				<p id="login-error">Wrong password. Try again.</p>
			</div>
		) : (
			<>
				<header>
					<h1>CaliDUIHelp — Leads Dashboard</h1>
					<span>{leads.length} total submissions</span>
				</header>
				<div class="container">
					<div class="stats">
						<div class="stat-card">
							<div class="num">{leads.length}</div>
							<div class="label">Total Leads</div>
						</div>
						<div class="stat-card">
							<div class="num">{leads.filter((l: any) => l.status === 'new').length}</div>
							<div class="label">New</div>
						</div>
						<div class="stat-card">
							<div class="num">{leads.filter((l: any) => l.status === 'sent').length}</div>
							<div class="label">Sent to Lawyer</div>
						</div>
					</div>

					<table>
						<thead>
							<tr>
								<th>#</th>
								<th>Name</th>
								<th>Contact</th>
								<th>ZIP</th>
								<th>Situation</th>
								<th>Date</th>
								<th>Status</th>
								<th>Send to Lawyer</th>
							</tr>
						</thead>
						<tbody>
							{leads.map((lead: any) => (
								<tr>
									<td>{lead.id}</td>
									<td><strong>{lead.full_name}</strong>{lead.description ? <><br /><small style="color:#888">{lead.description.slice(0, 60)}{lead.description.length > 60 ? '…' : ''}</small></> : null}</td>
									<td>{lead.email && <div>{lead.email}</div>}{lead.phone && <div>{lead.phone}</div>}</td>
									<td>{lead.zip_code}</td>
									<td>{lead.incident_type}</td>
									<td style="white-space:nowrap">{lead.incident_date ? new Date(lead.incident_date).toLocaleDateString() : '—'}<br /><small style="color:#aaa">{new Date(lead.created_at).toLocaleDateString()}</small></td>
									<td><span class={`badge ${lead.status === 'sent' ? 'badge-sent' : 'badge-new'}`}>{lead.status}</span>{lead.assigned_lawyer && <div style="font-size:0.78em;color:#666;margin-top:0.3em">{lead.assigned_lawyer}</div>}</td>
									<td>
										{lead.status === 'sent' ? (
											<span class="sent-label">✓ Sent</span>
										) : (
											<div class="send-form" data-id={lead.id}>
												<input type="email" placeholder="Lawyer email" />
												<button>Send</button>
											</div>
										)}
									</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</>
		)}

		<script>
			// Login
			const loginBtn = document.getElementById('login-btn');
			if (loginBtn) {
				loginBtn.addEventListener('click', async () => {
					const pw = (document.getElementById('pw-input') as HTMLInputElement).value;
					const res = await fetch('/api/admin-login', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ password: pw }),
					});
					if (res.ok) {
						window.location.reload();
					} else {
						const err = document.getElementById('login-error') as HTMLElement;
						err.style.display = 'block';
					}
				});
				const input = document.getElementById('pw-input') as HTMLInputElement;
				input?.addEventListener('keydown', (e) => { if (e.key === 'Enter') loginBtn.click(); });
			}

			// Send lead to lawyer
			document.querySelectorAll('.send-form').forEach((form) => {
				const btn = form.querySelector('button')!;
				btn.addEventListener('click', async () => {
					const leadId = (form as HTMLElement).dataset.id;
					const email = (form.querySelector('input') as HTMLInputElement).value;
					if (!email) { alert('Enter a lawyer email first.'); return; }
					btn.disabled = true;
					btn.textContent = 'Sending...';
					const res = await fetch('/api/send-lead', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ lead_id: leadId, lawyer_email: email }),
					});
					if (res.ok) {
						window.location.reload();
					} else {
						alert('Failed to send. Try again.');
						btn.disabled = false;
						btn.textContent = 'Send';
					}
				});
			});
		</script>
	</body>
</html>
