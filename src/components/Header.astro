---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
			<span></span>
			<span></span>
			<span></span>
		</button>
		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/bac-calculator">BAC Calculator</HeaderLink>
			<HeaderLink href="/cost-estimator">Cost Estimator</HeaderLink>
			<HeaderLink href="/dmv-hearing">DMV Hearing</HeaderLink>
			<a href="/what-to-do-first" class="cta-button">What do I do first?</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		position: relative;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		min-height: 56px;
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.cta-button {
		background: #cc0000;
		color: white !important;
		padding: 0.45em 1em !important;
		border-radius: 5px;
		font-weight: 700;
		border-bottom: none !important;
	}
	.cta-button:hover {
		background: #a30000;
		border-bottom: none !important;
	}
	.menu-toggle {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 8px;
	}
	.menu-toggle span {
		display: block;
		width: 24px;
		height: 2px;
		background: rgb(var(--black));
		border-radius: 2px;
	}
	@media (max-width: 720px) {
		.menu-toggle {
			display: flex;
		}
		.nav-links {
			display: none;
			flex-direction: column;
			align-items: stretch;
			width: 100%;
			padding-bottom: 0.5em;
		}
		.nav-links.open {
			display: flex;
		}
		.nav-links a {
			padding: 0.75em 0;
			border-bottom: 1px solid rgb(var(--gray-light)) !important;
			border-left: none !important;
		}
		.cta-button {
			text-align: center;
			border-radius: 5px;
			margin-top: 0.25em;
		}
	}
</style>
<script>
	const toggle = document.querySelector('.menu-toggle');
	const navLinks = document.querySelector('.nav-links');
	toggle?.addEventListener('click', () => {
		const isOpen = navLinks?.classList.toggle('open');
		toggle.setAttribute('aria-expanded', String(isOpen));
	});
</script>
