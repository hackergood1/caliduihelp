---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Check Your Options — California DUI Help"
			description="Find out what options are still available after a California DUI. Fill out the form to get connected with a legal professional in your area."
		/>
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			h1 {
				font-size: 1.6em;
				margin-bottom: 0.4em;
			}
			.intro {
				color: rgb(var(--gray-dark));
				margin-bottom: 1.5em;
				line-height: 1.7;
			}
			.disclaimer-box {
				background: #fff8e1;
				border-left: 4px solid #f59e0b;
				padding: 0.85em 1em;
				border-radius: 4px;
				font-size: 0.9em;
				color: #7c6400;
				margin-bottom: 1em;
			}
			.data-notice {
				background: #f0f4ff;
				border-left: 4px solid #2337ff;
				padding: 0.85em 1em;
				border-radius: 4px;
				font-size: 0.85em;
				color: rgb(var(--gray-dark));
				margin-bottom: 2em;
			}
			.form-group {
				margin-bottom: 1.2em;
			}
			label {
				display: block;
				font-weight: 700;
				margin-bottom: 0.3em;
				font-size: 0.95em;
			}
			label span.optional {
				font-weight: 400;
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			input, select, textarea {
				width: 100%;
				padding: 0.6em 0.8em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 5px;
				font-size: 1em;
				font-family: inherit;
				color: rgb(var(--black));
				background: white;
				box-sizing: border-box;
			}
			input:focus, select:focus, textarea:focus {
				outline: 2px solid #2337ff;
				border-color: transparent;
			}
			textarea {
				height: 100px;
				resize: vertical;
			}
			.consent-row {
				display: flex;
				align-items: flex-start;
				gap: 0.75em;
				background: #f8fafc;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 6px;
				padding: 1em;
				margin-bottom: 1.5em;
			}
			.consent-row input[type="checkbox"] {
				width: 18px;
				height: 18px;
				flex-shrink: 0;
				margin-top: 2px;
				cursor: pointer;
			}
			.consent-row label {
				font-weight: 400;
				font-size: 0.9em;
				margin: 0;
				color: rgb(var(--gray-dark));
				cursor: pointer;
			}
			.secure-note {
				font-size: 0.82em;
				color: rgb(var(--gray));
				margin-bottom: 1.2em;
			}
			.submit-btn {
				background: #cc0000;
				color: white;
				border: none;
				padding: 0.85em 2em;
				font-size: 1.05em;
				font-weight: 700;
				border-radius: 6px;
				cursor: pointer;
				width: 100%;
			}
			.submit-btn:hover {
				background: #a30000;
			}
			.submit-btn:disabled {
				background: #aaa;
				cursor: not-allowed;
			}
			#success-message {
				display: none;
				background: #f0fdf4;
				border-left: 4px solid #16a34a;
				padding: 1.2em 1em;
				border-radius: 6px;
				color: #166534;
				font-size: 0.95em;
				line-height: 1.7;
				margin-top: 1.5em;
			}
			#error-message {
				display: none;
				background: #fef2f2;
				border-left: 4px solid #cc0000;
				padding: 0.85em 1em;
				border-radius: 6px;
				color: #991b1b;
				font-size: 0.9em;
				margin-top: 1em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Check Your Options in Your Area</h1>
			<p class="intro">Fill out the form below and we'll help connect you with a legal professional in your area who can review your situation. It takes less than 2 minutes.</p>

			<div class="disclaimer-box">
				<strong>Important:</strong> We are not a law firm and do not provide legal advice. This page is designed to help connect you with independent attorneys or legal professionals in your area based on the information you provide.
			</div>

			<div class="data-notice">
				<strong>How your information is used:</strong> By submitting this form, you understand that the information you provide may be shared with attorneys or legal professionals in your area so they can review your situation and contact you if appropriate. We do not guarantee representation or outcomes.
			</div>

			<form id="lead-form">
				<div class="form-group">
					<label for="full_name">Full Name</label>
					<input type="text" id="full_name" name="full_name" required placeholder="Your full name" />
				</div>

				<div class="form-group">
					<label for="email">Email Address</label>
					<input type="email" id="email" name="email" placeholder="your@email.com" />
				</div>

				<div class="form-group">
					<label for="phone">Phone Number</label>
					<input type="tel" id="phone" name="phone" placeholder="(555) 000-0000" />
				</div>

				<div class="form-group">
					<label for="zip_code">ZIP Code</label>
					<input type="text" id="zip_code" name="zip_code" required placeholder="e.g. 90210" maxlength="10" />
				</div>

				<div class="form-group">
					<label for="incident_type">Your Situation</label>
					<select id="incident_type" name="incident_type" required>
						<option value="" disabled selected>Select your situation</option>
						<option value="First DUI">First DUI</option>
						<option value="Second or subsequent DUI">Second or subsequent DUI</option>
						<option value="DUI with injury or accident">DUI with injury or accident</option>
						<option value="Refusal to test">Refusal to test</option>
						<option value="Under 21 DUI">Under 21 DUI</option>
						<option value="DMV hearing only">DMV hearing only</option>
						<option value="Other">Other</option>
					</select>
				</div>

				<div class="form-group">
					<label for="incident_date">Date of Incident <span class="optional">(optional)</span></label>
					<input type="date" id="incident_date" name="incident_date" />
				</div>

				<div class="form-group">
					<label for="description">Brief Description <span class="optional">(optional)</span></label>
					<textarea id="description" name="description" placeholder="Anything else you'd like us to know about your situation..."></textarea>
				</div>

				<div class="consent-row">
					<input type="checkbox" id="consent" name="consent" required />
					<label for="consent">I understand that this website is not a law firm, and I agree that my information may be shared with legal professionals in my area who may contact me regarding my situation.</label>
				</div>

				<p class="secure-note">🔒 Your information is kept secure and only used to help connect you with relevant legal professionals.</p>

				<button type="submit" class="submit-btn" id="submit-btn">Check My Options</button>
				<div id="error-message"></div>
			</form>

			<div id="success-message">
				<strong>Thank you for submitting your information.</strong><br /><br />
				Based on your situation, you may be contacted by a legal professional in your area. Be sure to keep your phone nearby and check your email. We'll be in touch soon.
			</div>
		</main>
		<CookieBanner />
		<Footer />

		<script>
			const form = document.getElementById('lead-form') as HTMLFormElement;
			const btn = document.getElementById('submit-btn') as HTMLButtonElement;
			const successMsg = document.getElementById('success-message') as HTMLDivElement;
			const errorMsg = document.getElementById('error-message') as HTMLDivElement;

			form.addEventListener('submit', async (e) => {
				e.preventDefault();
				btn.disabled = true;
				btn.textContent = 'Submitting...';
				errorMsg.style.display = 'none';

				const payload = {
					full_name: (document.getElementById('full_name') as HTMLInputElement).value,
					email: (document.getElementById('email') as HTMLInputElement).value,
					phone: (document.getElementById('phone') as HTMLInputElement).value,
					zip_code: (document.getElementById('zip_code') as HTMLInputElement).value,
					incident_type: (document.getElementById('incident_type') as HTMLSelectElement).value,
					incident_date: (document.getElementById('incident_date') as HTMLInputElement).value,
					description: (document.getElementById('description') as HTMLTextAreaElement).value,
					consent_checked: (document.getElementById('consent') as HTMLInputElement).checked,
				};

				try {
					const res = await fetch('/api/lead', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify(payload),
					});
					const data = await res.json();

					if (res.ok) {
						form.style.display = 'none';
						successMsg.style.display = 'block';
					} else {
						errorMsg.textContent = data.error || 'Something went wrong. Please try again.';
						errorMsg.style.display = 'block';
						btn.disabled = false;
						btn.textContent = 'Check My Options';
					}
				} catch {
					errorMsg.textContent = 'Network error. Please check your connection and try again.';
					errorMsg.style.display = 'block';
					btn.disabled = false;
					btn.textContent = 'Check My Options';
				}
			});
		</script>
	</body>
</html>
